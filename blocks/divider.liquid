<hr class="{{ block.settings.spacing }}{% unless block.settings.show_line %} invisible{% endunless %}" {{ block.shopify_attributes }}>

{% schema %}
  {
    "name": "Divider",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_line",
        "label": "Show line",
        "default": true
      },
      {
        "type": "select",
        "id": "spacing",
        "label": "Spacing",
        "options": [
          {
            "value": "mt-8 mb-8",
            "label": "Default"
          },
          {
            "value": "mt-12 mb-12",
            "label": "Large"
          }
        ],
        "default": "mt-8 mb-8"
      }
    ],
    "presets": [
      {
        "name": "Divider"
      }
    ]
  }
{% endschema %}